# Production environment template. Copy to .env.prod and fill real values.
#   cp .env.prod.example .env.prod
# NEVER commit .env.prod or real secrets. The app runs with SPRING_PROFILES_ACTIVE=prod,postgres,
# so the ProductionStartupValidator refuses to boot if any of the hardening rules below are violated.

# ---- Ports ----
APP_PORT=8080
HTTP_PORT=80

# ---- PostgreSQL (required; H2 is rejected in prod) ----
DB_NAME=agent_demo
DB_USERNAME=agent_demo
DB_PASSWORD=

# ---- Security: JWT (issuer mode strongly recommended in prod) ----
DEMO_SECURITY_JWT_MODE=issuer
# Configure ONE of issuer-uri / jwk-set-uri from your identity provider:
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://your-idp.example/realms/agent
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=https://your-idp.example/realms/agent/protocol/openid-connect/certs
# dev-token must be disabled in prod (front the console with your IdP instead).
DEMO_SECURITY_DEV_TOKEN_ENABLED=false
DEMO_SECURITY_RATE_LIMIT_BACKEND=external
# HMAC fallback (NOT recommended for prod). If you must use it, set jwt-mode=hmac and a strong 32+ byte secret:
# DEMO_SECURITY_JWT_MODE=hmac
# DEMO_SECURITY_JWT_SECRET=

# ---- Alibaba strict runtime (required in prod) ----
DEMO_ALIBABA_STRICT_MODE=true
DEMO_AI_FALLBACK_ENABLED=false
DEMO_RAG_KEYWORD_FALLBACK_ENABLED=false
DEMO_RAG_RETRIEVER=dashvector
DEMO_WORKFLOW_RUNTIME=graph

# ---- DashScope (chat + embedding) ----
AI_DASHSCOPE_API_KEY=your-dashscope-api-key
AI_DASHSCOPE_CHAT_MODEL=qwen-plus
AI_DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
AI_DASHSCOPE_EMBEDDING_DIMENSION=1024

# ---- DashVector ----
DASHVECTOR_ENDPOINT=https://your-instance.dashvector.cn-hangzhou.aliyuncs.com
DASHVECTOR_API_KEY=your-dashvector-api-key
DASHVECTOR_COLLECTION=agent_rag_docs
DASHVECTOR_DIMENSION=1024
DASHVECTOR_METRIC=cosine

# ---- MCP (off by default) ----
DEMO_MCP_ENABLED=false
