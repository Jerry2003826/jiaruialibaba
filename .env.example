# 阿里严格模式（dev + .env 默认开启；CI 测试请设 DEMO_ALIBABA_STRICT_MODE=false）
DEMO_ALIBABA_STRICT_MODE=true
DEMO_AI_FALLBACK_ENABLED=false
DEMO_RAG_KEYWORD_FALLBACK_ENABLED=false

# API 鉴权（/api/** 需要 JWT；/api/health 与 /api/auth/dev-token 公开）
#  - hmac（默认）：用 DEMO_SECURITY_JWT_SECRET 校验 HS256，本地/演示用。secret 至少 32 字节。
#    不设置时使用内置的不安全默认值，仅供本机演示；任何共享环境务必覆盖。
#  - issuer：改用标准 OIDC，设 DEMO_SECURITY_JWT_MODE=issuer 并配置
#    spring.security.oauth2.resourceserver.jwt.issuer-uri / jwk-set-uri（推荐生产使用）。
DEMO_SECURITY_JWT_MODE=hmac
DEMO_SECURITY_JWT_SECRET=
# 内置工作台用的开发令牌端点（/api/auth/dev-token）。生产请设为 false 并由真实 IdP 接管登录。
DEMO_SECURITY_DEV_TOKEN_ENABLED=true

# HTTP 工作流凭据加密主密钥。生产必须使用独立的 32 字节以上随机值。
DEMO_HTTP_CREDENTIAL_MASTER_KEY=
# 默认禁止 localhost/私网；确需访问内部 API 时由管理员显式配置逗号分隔主机名。
DEMO_WORKFLOW_HTTP_ALLOWED_HOSTS=

# PostgreSQL（dev profile 默认启用 postgres；docker compose up -d 后启动应用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent_demo
DB_USERNAME=agent_demo
DB_PASSWORD=agent_demo

# DashScope / 百炼 API Key（二选一，推荐 AI_DASHSCOPE_API_KEY）
AI_DASHSCOPE_API_KEY=
DASHSCOPE_API_KEY=

# Chat 模型：公网 DashScope 用 qwen-plus；MaaS 专属 endpoint 示例见下方
AI_DASHSCOPE_CHAT_MODEL=qwen-plus
AI_DASHSCOPE_BASE_URL=
AI_DASHSCOPE_CHAT_COMPLETIONS_PATH=

# qwen3.7-max MaaS（与 Python Generation.call + base_http_api_url 对齐）：
# AI_DASHSCOPE_CHAT_MODEL=qwen3.7-max
# AI_DASHSCOPE_BASE_URL=https://your-maas-endpoint.cn-beijing.maas.aliyuncs.com/api/v1
# AI_DASHSCOPE_CHAT_COMPLETIONS_PATH=/services/aigc/text-generation/generation
# AI_DASHSCOPE_ENABLE_THINKING=true
#
# qwen3.7-plus 可走 multimodal-generation：
# AI_DASHSCOPE_CHAT_COMPLETIONS_PATH=/services/aigc/multimodal-generation/generation

AI_DASHSCOPE_ENABLE_THINKING=false

# Tavily network search nodes. Can also be entered at Settings > Tavily network search.
TAVILY_API_KEY=

# Embedding 默认走 DashScope 公网；仅 embedding 也需要专属 endpoint 时才设置
AI_DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
AI_DASHSCOPE_EMBEDDING_DIMENSION=1024
AI_DASHSCOPE_EMBEDDING_BASE_URL=

DASHVECTOR_ENDPOINT=
DASHVECTOR_API_KEY=
DASHVECTOR_COLLECTION=agent_rag_docs
DASHVECTOR_DIMENSION=1024
DASHVECTOR_METRIC=cosine

DEMO_RAG_RETRIEVER=dashvector
DEMO_RAG_CHUNK_SIZE=800
DEMO_RAG_CHUNK_OVERLAP=120
DEMO_RAG_TOP_K=5

# simple | graph
DEMO_WORKFLOW_RUNTIME=graph

# MCP client is off by default. Set true only after configuring remote MCP servers
# through Spring AI properties, for example spring.ai.mcp.client.sse.* or
# spring.ai.mcp.client.streamable-http.* in application-dev.yml or environment.
DEMO_MCP_ENABLED=false
DEMO_MCP_TOOLCALLBACK_ENABLED=false
DEMO_MCP_ANNOTATION_SCANNER_ENABLED=false
DEMO_TOOLS_ALLOW_ALL_REMOTE_TOOLS=false
DEMO_TOOLS_ALLOWED_REMOTE_TOOLS=github:get_file_contents,github:search_repositories,github:list_commits,github:get_commit,github:list_branches

# Optional GitHub MCP profile. Fill GITHUB_PERSONAL_ACCESS_TOKEN only in your
# local shell or .env; never commit a real GitHub token.
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GITHUB_MCP_SERVER_COMMAND=github-mcp-server
# GITHUB_MCP_TOOLSETS=repos
# DEMO_MCP_SERVER_NAME=github
